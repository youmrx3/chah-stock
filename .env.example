VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_anon_key"

# Required for admin access (comma-separated list, lower/upper case accepted)
VITE_ADMIN_EMAILS="admin@example.com"

# Security mode:
# true  = require admin allowlist (recommended production)
# false = allow authenticated users when allowlist is missing (useful for local development)
VITE_REQUIRE_ADMIN_ALLOWLIST="false"